{
  "entities": {
    "Member": {
      "title": "Member Profile",
      "description": "Church member profile information.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "department": { "type": "string" },
        "role": { "type": "string" },
        "status": { "type": "string" },
        "registeredAt": { "type": "string", "format": "date-time" },
        "notes": { "type": "string" }
      },
      "required": ["id", "name", "registeredAt", "status"]
    },
    "Attendance": {
      "title": "Attendance Record",
      "description": "Weekly service or event attendance record for members.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "eventId": { "type": "string" },
        "eventTitle": { "type": "string" },
        "date": { "type": "string" },
        "memberId": { "type": "string" },
        "memberName": { "type": "string" },
        "status": { "type": "string", "enum": ["Present", "Absent", "Excused"] },
        "recordedBy": { "type": "string" },
        "recordedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "memberId", "memberName", "status", "date"]
    },
    "Finance": {
      "title": "Financial Transaction",
      "description": "Tithes, offerings, and donations received.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "enum": ["Tithe", "Offering", "Donation", "Other"] },
        "amount": { "type": "number" },
        "date": { "type": "string" },
        "donorName": { "type": "string" },
        "memberId": { "type": "string" },
        "notes": { "type": "string" },
        "recordedBy": { "type": "string" },
        "recordedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "type", "amount", "date", "donorName", "recordedAt"]
    },
    "Department": {
      "title": "Department/Ministry Info",
      "description": "Information about a specific ministry or team.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "leaderName": { "type": "string" },
        "leaderId": { "type": "string" },
        "description": { "type": "string" },
        "meetingTime": { "type": "string" }
      },
      "required": ["id", "name"]
    },
    "Event": {
      "title": "Church Event",
      "description": "Church-wide events and service schedules.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "dateTime": { "type": "string", "format": "date-time" },
        "location": { "type": "string" },
        "category": { "type": "string" },
        "registrationsCount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "title", "dateTime"]
    }
  },
  "firestore": {
    "/members/{memberId}": {
      "schema": "Member",
      "description": "Collection of church members."
    },
    "/attendance/{attendanceId}": {
      "schema": "Attendance",
      "description": "Collection of attendance marks."
    },
    "/finances/{financeId}": {
      "schema": "Finance",
      "description": "Collection of tithing and donation transactions."
    },
    "/departments/{departmentId}": {
      "schema": "Department",
      "description": "Collection of ministry and volunteer departments."
    },
    "/events/{eventId}": {
      "schema": "Event",
      "description": "Collection of custom church events."
    }
  }
}
