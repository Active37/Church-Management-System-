{
  "entities": {
    "Member": {
      "title": "Member Profile",
      "description": "Church member profile information.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "department": { "type": "string" },
        "role": { "type": "string" },
        "status": { "type": "string" },
        "registeredAt": { "type": "string", "format": "date-time" },
        "notes": { "type": "string" }
      },
      "required": ["id", "name", "registeredAt", "status"]
    },
    "Attendance": {
      "title": "Attendance Record",
      "description": "Weekly service or event attendance record for members.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "eventId": { "type": "string" },
        "eventTitle": { "type": "string" },
        "date": { "type": "string" },
        "memberId": { "type": "string" },
        "memberName": { "type": "string" },
        "status": { "type": "string", "enum": ["Present", "Absent", "Excused"] },
        "recordedBy": { "type": "string" },
        "recordedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "memberId", "memberName", "status", "date"]
    },
    "Finance": {
      "title": "Financial Transaction",
      "description": "Tithes, offerings, and donations received.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "enum": ["Tithe", "Offering", "Donation", "Other"] },
        "amount": { "type": "number" },
        "date": { "type": "string" },
        "donorName": { "type": "string" },
        "memberId": { "type": "string" },
        "notes": { "type": "string" },
        "recordedBy": { "type": "string" },
        "recordedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "type", "amount", "date", "donorName", "recordedAt"]
    },
    "Department": {
      "title": "Department/Ministry Info",
      "description": "Information about a specific ministry or team.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "leaderName": { "type": "string" },
        "leaderId": { "type": "string" },
        "description": { "type": "string" },
        "meetingTime": { "type": "string" }
      },
      "required": ["id", "name"]
    },
    "Event": {
      "title": "Church Event",
      "description": "Church-wide events and service schedules.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "dateTime": { "type": "string", "format": "date-time" },
        "location": { "type": "string" },
        "category": { "type": "string" },
        "registrationsCount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "title", "dateTime"]
    },
    "VolunteerSchedule": {
      "title": "Volunteer Schedule",
      "description": "Assigned roles for events or regular services.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "eventId": { "type": "string" },
        "eventTitle": { "type": "string" },
        "dateTime": { "type": "string" },
        "roleName": { "type": "string" },
        "memberId": { "type": "string" },
        "memberName": { "type": "string" },
        "memberEmail": { "type": "string" },
        "status": { "type": "string", "enum": ["Assigned", "Confirmed", "Declined"] },
        "requirements": { "type": "string" }
      },
      "required": ["id", "eventId", "eventTitle", "dateTime", "roleName", "status"]
    },
    "Announcement": {
      "title": "Announcement",
      "description": "General or urgent broadcast message to the entire church.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "senderName": { "type": "string" },
        "senderEmail": { "type": "string" },
        "category": { "type": "string", "enum": ["General", "Urgent", "Ministry"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "title", "content", "category", "createdAt"]
    },
    "ChatMessage": {
      "title": "Chat Message",
      "description": "Real-time communication in groups or direct messages.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "groupId": { "type": "string" },
        "groupName": { "type": "string" },
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "senderEmail": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "groupId", "senderId", "content", "createdAt"]
    },
    "EventFeedback": {
      "title": "Event Feedback",
      "description": "Post-event rating and review by participants.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "eventId": { "type": "string" },
        "eventTitle": { "type": "string" },
        "rating": { "type": "number" },
        "comment": { "type": "string" },
        "submitterName": { "type": "string" },
        "submitterEmail": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "eventId", "eventTitle", "rating", "createdAt"]
    },
    "SystemActivity": {
      "title": "System Activity",
      "description": "Logged deletions or modifications to crucial system profiles.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "actionType": { "type": "string", "enum": ["Modification", "Deletion"] },
        "targetType": { "type": "string", "enum": ["Member", "Event"] },
        "targetId": { "type": "string" },
        "targetName": { "type": "string" },
        "details": { "type": "string" }
      },
      "required": ["id", "timestamp", "userId", "userEmail", "actionType", "targetType", "targetId", "targetName", "details"]
    }
  },
  "firestore": {
    "/members/{memberId}": {
      "schema": "Member",
      "description": "Collection of church members."
    },
    "/attendance/{attendanceId}": {
      "schema": "Attendance",
      "description": "Collection of attendance marks."
    },
    "/finances/{financeId}": {
      "schema": "Finance",
      "description": "Collection of tithing and donation transactions."
    },
    "/departments/{departmentId}": {
      "schema": "Department",
      "description": "Collection of ministry and volunteer departments."
    },
    "/events/{eventId}": {
      "schema": "Event",
      "description": "Collection of custom church events."
    },
    "/volunteer_schedules/{scheduleId}": {
      "schema": "VolunteerSchedule",
      "description": "Collection of assigned volunteer shifts."
    },
    "/announcements/{announcementId}": {
      "schema": "Announcement",
      "description": "Collection of board announcements."
    },
    "/chats/{chatId}": {
      "schema": "ChatMessage",
      "description": "Collection of group and private messages."
    },
    "/feedbacks/{feedbackId}": {
      "schema": "EventFeedback",
      "description": "Collection of post-event feedback survey responses."
    },
    "/system_activities/{activityId}": {
      "schema": "SystemActivity",
      "description": "Collection of custom critical system operations logged synchronously."
    }
  }
}
